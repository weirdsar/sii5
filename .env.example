# Скопируйте в `.env` и подставьте значения. Файл `.env` не коммитится.

# Яндекс.Метрика — ID счётчика (только цифры). Доступен в браузере как PUBLIC_*.
# Альтернатива: файл `.yandex.metrika.env` в корне (вставка кода из конструктора Метрики или строка PUBLIC_METRIKA_ID=…)
# — подхватывается в `astro.config.mjs` при сборке и в dev.
PUBLIC_METRIKA_ID=

# Путь зеркала заявок (same-origin на проде). На Cloudflare Pages задайте в билде:
# PUBLIC_MAX_LEAD_MIRROR_PATH=/api/max-lead-mirror
# По умолчанию в коде — Netlify: /.netlify/functions/max-lead-mirror
PUBLIC_MAX_LEAD_MIRROR_PATH=

# --- Заявки в MAX (Netlify Function или Cloudflare Pages Function) ---
#
# Вариант A — напрямую в чат MAX (без своего PHP; токен только в Netlify, не в git):
#   MAX_BOT_TOKEN=...          # business.max.ru → Чат-боты → Интеграция (как в проекте Gidra)
#   MAX_NOTIFY_USER_ID=...    # алиас имени из Gidra `.deploy/.max.env` (или MAX_USER_ID)
#   MAX_CHAT_ID=...            # или MAX_NOTIFY_CHAT_ID — группа; приоритет у user_id, как в Gidra PHP
# Узнать chat_id: GET https://platform-api.max.ru/chats с тем же Authorization (см. max_bot_instrukt.md).
#
# Вариант B — свой HTTPS-приёмник (прокси):
#   MAX_LEAD_WEBHOOK_URL=https://...
#   или PUBLIC_MAX_BOT_URL (попадёт в клиент на localhost)
#   MAX_LEAD_WEBHOOK_BODY_FORMAT=form  # если PHP ждёт x-www-form-urlencoded
#
# Локально при astro dev CF-функция не поднимается — тест: netlify dev, wrangler pages dev или PUBLIC_MAX_BOT_URL.
PUBLIC_MAX_BOT_URL=
