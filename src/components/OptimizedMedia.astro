---
/**
 * Локальное изображение из `astro:assets`: SVG остаётся вектором через `<Image />`;
 * растр — `<Picture />` (AVIF, WebP, оригинал в `<img>`).
 */
import { Image, Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  /** Результат ESM-импорта картинки из `src/assets/`. */
  src: ImageMetadata;
  alt: string;
  class?: string;
  loading?: 'eager' | 'lazy' | null;
  decoding?: 'async' | 'auto' | 'sync' | null;
  /** Для растра; у SVG игнорируется. Пресеты Astro/Sharp: `low` / `mid` / `high` / `max` или число 0–100. */
  quality?: 'low' | 'mid' | 'high' | 'max' | number;
}

const { src, alt, class: className, loading, decoding, quality = 'mid' } = Astro.props;
const isSvg = src.format === 'svg';
---

{isSvg ? (
  <Image src={src} alt={alt} class={className} loading={loading} decoding={decoding} />
) : (
  <Picture
    src={src}
    alt={alt}
    class={className}
    loading={loading}
    decoding={decoding}
    formats={['avif', 'webp']}
    quality={quality}
  />
)}
