---
/**
 * Первый экран главной: тёмный герой с двумя CTA и декором.
 */
interface Props {
  /** Разрешён HTML в заголовке (акцент через `<span>`). */
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  title = 'Создаю <span class="text-accent">продающие сайты</span> для малого бизнеса в РФ',
  subtitle = 'Лендинги, корпоративные сайты и интернет-магазины, которые приносят заявки и клиентов',
  ctaText = 'Смотреть кейсы',
  ctaHref = '/cases',
  secondaryCtaText = 'Обсудить проект',
  secondaryCtaHref = '/contact',
} = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden">
  <!-- Градиентный фон -->
  <div class="absolute inset-0 bg-gradient-to-br from-surface-dark via-primary-dark/90 to-surface-dark"></div>

  <!-- Декоративные круги -->
  <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-primary/20 blur-3xl animate-float"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-accent/20 blur-3xl animate-float-delayed"></div>

  <!-- Сетка точек (декор) -->
  <div class="absolute inset-0 opacity-5">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dots" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1" fill="white"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dots)"/>
    </svg>
  </div>

  <!-- Контент -->
  <div class="container-custom relative z-10 py-20 md:py-32">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Левая колонка: текст -->
      <div>
        <!-- Бейдж -->
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium bg-accent/20 text-accent mb-6">
          🚀 Веб-разработчик из Саратова
        </span>

        <!-- Заголовок -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6" set:html={title}></h1>

        <!-- Подзаголовок -->
        <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-lg">
          {subtitle}
        </p>

        <!-- Кнопки -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={ctaHref} class="btn-accent text-lg px-8 py-4">
            {ctaText}
          </a>
          <a href={secondaryCtaHref} class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-surface-dark transition-colors text-lg">
            {secondaryCtaText}
          </a>
        </div>
      </div>

      <!-- Правая колонка: окно браузера (скрыто на мобильных) -->
      <div class="hidden md:block">
        <div class="bg-gray-800 rounded-2xl shadow-2xl overflow-hidden border border-gray-700">
          <!-- Панель браузера -->
          <div class="bg-gray-900 px-4 py-3 flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
            <div class="ml-4 flex-1 bg-gray-800 rounded px-3 py-1 text-gray-500 text-xs">
              sii5.ru
            </div>
          </div>
          <!-- Код-декор -->
          <div class="p-6 font-mono text-sm leading-relaxed">
            <p class="text-gray-500">// Создаём продающий сайт</p>
            <p class="mt-2">
              <span class="text-purple-400">const</span>
              <span class="text-blue-400"> сайт</span>
              <span class="text-white"> = </span>
              <span class="text-yellow-400">создатьСайт</span>
              <span class="text-white">({"{"}</span>
            </p>
            <p class="pl-4">
              <span class="text-blue-300">клиент</span>
              <span class="text-white">: </span>
              <span class="text-accent">'Ваш бизнес'</span>
              <span class="text-white">,</span>
            </p>
            <p class="pl-4">
              <span class="text-blue-300">цель</span>
              <span class="text-white">: </span>
              <span class="text-green-400">'Больше заявок'</span>
              <span class="text-white">,</span>
            </p>
            <p class="pl-4">
              <span class="text-blue-300">результат</span>
              <span class="text-white">: </span>
              <span class="text-green-400">'Рост продаж'</span>
            </p>
            <p class="text-white">{"}"});</p>
            <p class="mt-4 text-gray-500">// ✓ Готово за 2-4 недели</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 6s ease-in-out infinite;
    animation-delay: 3s;
  }
</style>
