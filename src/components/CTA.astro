---
/**
 * Градиентный призыв к действию: основная и опциональная вторичная кнопка.
 */
interface Props {
  title?: string;
  subtitle?: string;
  /** Текст и ссылка основной кнопки (по умолчанию заявка на `/contact`). */
  ctaText?: string;
  ctaHref?: string;
  /** Вторичная ссылка (например бриф PDF). */
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  title = 'Готовы обсудить ваш проект?',
  subtitle = 'Оставьте заявку — отвечу в течение 2 часов в рабочее время',
  ctaText = 'Оставить заявку',
  ctaHref = '/contact',
  secondaryCtaText,
  secondaryCtaHref,
} = Astro.props;
---

<section class="py-16 md:py-24">
  <div class="container-custom">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-r from-primary to-primary-dark p-8 md:p-16 text-center" data-reveal>
      <!-- Декоративные круги -->
      <div class="absolute -left-16 -top-16 w-64 h-64 rounded-full bg-white/10"></div>
      <div class="absolute -right-8 -bottom-8 w-48 h-48 rounded-full bg-white/10"></div>

      <!-- Контент -->
      <h2 class="relative z-10 text-3xl md:text-4xl font-bold text-white mb-4">{title}</h2>
      <p class="relative z-10 text-lg text-blue-100 mb-8 max-w-xl mx-auto">{subtitle}</p>
      <div class="relative z-10 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={ctaHref} class="btn-accent text-lg px-10 py-4">
          {ctaText}
        </a>
        {secondaryCtaText && secondaryCtaHref && (
          <a
            href={secondaryCtaHref}
            class="inline-flex items-center justify-center px-8 py-3.5 rounded-lg border-2 border-white/80 text-white font-semibold hover:bg-white/10 transition-colors text-base"
          >
            {secondaryCtaText}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
