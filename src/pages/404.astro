---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Страница не найдена" description="Запрашиваемая страница не существует">
  <section class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center px-4">
      <h1 class="text-8xl md:text-9xl font-bold text-primary mb-4">404</h1>
      <p class="text-2xl md:text-3xl font-bold text-text-main mb-2">Страница не найдена</p>
      <p class="text-text-muted mb-8 max-w-md mx-auto">
        Возможно, она была перемещена или удалена. Вернитесь на главную или выберите раздел в меню.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">Вернуться на главную</a>
        <a href="/cases" class="btn-outline">Смотреть кейсы</a>
      </div>
    </div>
  </section>
</BaseLayout>
