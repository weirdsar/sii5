---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTA from '../components/CTA.astro';

const serviceEntries = await getCollection('services');
const services = [...serviceEntries].sort((a, b) => a.data.order - b.data.order);

const additionalEntries = await getCollection('additionalServices');
const additionalServices = [...additionalEntries].sort(
  (a, b) => a.data.order - b.data.order
);

const workSteps = [
  {
    number: 1,
    title: 'Знакомство',
    description: 'Обсуждаем задачу, цели, бюджет. Бесплатная консультация.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
  },
  {
    number: 2,
    title: 'Проектирование',
    description: 'Создаю прототип и дизайн. Утверждаем до начала разработки.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v7a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm16 0a1 1 0 011-1h4a1 1 0 011 1v7a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zm-8 9a1 1 0 011-1h4a1 1 0 011 1v7a1 1 0 01-1 1h-4a1 1 0 01-1-1v-7z"/></svg>`,
  },
  {
    number: 3,
    title: 'Разработка',
    description: 'Верстаю и программирую. Показываю промежуточные результаты.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
  },
  {
    number: 4,
    title: 'Запуск',
    description: 'Тестирую, размещаю на хостинге, настраиваю аналитику.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>`,
  },
];
---

<BaseLayout
  title="Услуги и цены"
  description="Разработка сайтов для малого бизнеса: лендинги от 25 000 ₽, корпоративные сайты от 50 000 ₽. Полный цикл от дизайна до запуска."
>
  <!-- Шапка -->
  <section class="bg-surface-dark py-16 md:py-24">
    <div class="container-custom text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Услуги и цены</h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        Прозрачные цены, понятные условия. Выберите подходящий формат или обсудим индивидуальный проект.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/brief/"
          class="inline-flex items-center gap-2 rounded-lg border border-white/30 bg-white/10 px-5 py-2.5 text-sm font-semibold text-white hover:bg-white/15 transition-colors"
        >
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Скачать бриф сайта (PDF)
        </a>
      </div>
    </div>
  </section>

  <!-- Тарифные карточки -->
  <section class="py-16 md:py-24">
    <div class="container-custom">
      <div class="grid md:grid-cols-3 gap-8 items-start">
        {services.map((entry) => (
          <ServiceCard
            id={entry.id}
            name={entry.data.title}
            subtitle={entry.data.description}
            price={entry.data.price}
            features={entry.data.features}
            highlighted={entry.data.highlighted}
            cta={entry.data.cta}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Дополнительные услуги -->
  <section class="py-16 md:py-24 bg-surface-light">
    <div class="container-custom">
      <h2 class="text-3xl font-bold text-text-main text-center mb-12" data-reveal>
        Дополнительные услуги
      </h2>
      <div class="grid md:grid-cols-2 gap-6">
        {additionalServices.map((s, index) => (
          <div
            class="bg-card rounded-xl p-6 border border-border-subtle flex justify-between items-start gap-4"
            data-reveal
            data-reveal-delay={String(index * 100)}
          >
            <div>
              <h3 class="font-bold text-text-main mb-1">{s.data.title}</h3>
              <p class="text-text-muted text-sm">{s.data.description}</p>
            </div>
            <span class="text-primary font-bold whitespace-nowrap shrink-0">{s.data.price}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Как я работаю -->
  <section class="py-16 md:py-24">
    <div class="container-custom">
      <h2 class="text-3xl font-bold text-text-main text-center mb-12" data-reveal>
        Как я работаю
      </h2>
      <div class="grid md:grid-cols-4 gap-8">
        {workSteps.map((step, index) => (
          <div class="text-center" data-reveal data-reveal-delay={String(index * 100)}>
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-xl">
              {step.number}
            </div>
            <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center text-primary" set:html={step.icon}></div>
            <h3 class="font-bold text-text-main mb-2">{step.title}</h3>
            <p class="text-text-muted text-sm">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    secondaryCtaText="Скачать бриф сайта (PDF)"
    secondaryCtaHref="/brief/"
  />
</BaseLayout>
