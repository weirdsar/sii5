---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import CTA from '../../components/CTA.astro';
import { getTotalArticlePages, sliceArticlesForListPage } from '../../utils/articles-pagination';
import { ogImagePathForArticle } from '../../utils/ogImagePaths';

const entries = await getCollection('articles');
const sorted = [...entries].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const totalPages = getTotalArticlePages(sorted.length);
const articles = sliceArticlesForListPage(sorted, 1);
---

<BaseLayout
  title="Статьи о веб-разработке"
  description="Полезные статьи о создании сайтов, продвижении и развитии бизнеса в интернете."
>
  <!-- Шапка -->
  <section class="bg-surface-dark py-16 md:py-24">
    <div class="container-custom text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Статьи</h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        Делюсь опытом и полезными знаниями о веб-разработке,
        продвижении бизнеса в интернете и цифровых инструментах.
      </p>
    </div>
  </section>

  <!-- Список статей -->
  <section class="py-16 md:py-24">
    <div class="container-custom">
      {articles.length > 0 ? (
        <>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {articles.map((entry) => {
              const dateStr = entry.data.date.toISOString().slice(0, 10);
              return (
                <ArticleCard
                  slug={entry.id}
                  title={entry.data.title}
                  excerpt={entry.data.excerpt}
                  date={dateStr}
                  readTime={entry.data.readTime}
                  tags={entry.data.tags}
                  coverUrl={ogImagePathForArticle(entry.id)}
                />
              );
            })}
          </div>
          {totalPages > 1 && (
            <nav
              class="mt-12 flex flex-wrap items-center justify-center gap-2"
              aria-label="Навигация по страницам статей"
            >
              <span class="text-sm text-text-muted px-3 py-2 rounded-lg bg-primary/10 text-primary font-medium">
                1
              </span>
              {Array.from({ length: totalPages - 1 }, (_, i) => i + 2).map((num) => (
                <a
                  href={`/articles/page/${num}/`}
                  class="text-sm text-text-muted hover:text-primary px-3 py-2 rounded-lg border border-border-subtle hover:border-primary/40 transition-colors"
                >
                  {num}
                </a>
              ))}
            </nav>
          )}
        </>
      ) : (
        <p class="text-center text-text-muted text-lg">
          Статьи скоро появятся. Следите за обновлениями!
        </p>
      )}
    </div>
  </section>

  <!-- CTA -->
  <CTA
    title="Есть вопросы по разработке?"
    subtitle="Напишите — помогу разобраться и подскажу лучшее решение"
  />
</BaseLayout>
