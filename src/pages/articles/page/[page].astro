---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import CTA from '../../../components/CTA.astro';
import {
  getTotalArticlePages,
  sliceArticlesForListPage,
} from '../../../utils/articles-pagination';
import { ogImagePathForArticle } from '../../../utils/ogImagePaths';

export async function getStaticPaths() {
  const entries = await getCollection('articles');
  const sorted = [...entries].sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  );
  const total = getTotalArticlePages(sorted.length);
  if (total <= 1) return [];
  return Array.from({ length: total - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const pageNum = Math.max(2, parseInt(Astro.params.page ?? '2', 10) || 2);
const entries = await getCollection('articles');
const sorted = [...entries].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const totalPages = getTotalArticlePages(sorted.length);
const articles = sliceArticlesForListPage(sorted, pageNum);

if (pageNum > totalPages || pageNum < 2) {
  return Astro.redirect('/articles/');
}

const title = pageNum === 2 ? 'Статьи — страница 2' : `Статьи — страница ${pageNum}`;
const description =
  'Полезные статьи о создании сайтов, продвижении и развитии бизнеса в интернете.';
---

<BaseLayout title={title} description={description}>
  <section class="bg-surface-dark py-16 md:py-24">
    <div class="container-custom text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Статьи</h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        Страница {pageNum} из {totalPages}
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container-custom">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {articles.map((entry) => {
          const dateStr = entry.data.date.toISOString().slice(0, 10);
          return (
            <ArticleCard
              slug={entry.id}
              title={entry.data.title}
              excerpt={entry.data.excerpt}
              date={dateStr}
              readTime={entry.data.readTime}
              tags={entry.data.tags}
              coverUrl={ogImagePathForArticle(entry.id)}
            />
          );
        })}
      </div>

      <nav
        class="mt-12 flex flex-wrap items-center justify-center gap-2"
        aria-label="Навигация по страницам статей"
      >
        {pageNum > 2 ? (
          <a
            href={pageNum === 3 ? '/articles/' : `/articles/page/${pageNum - 1}/`}
            class="text-sm text-text-muted hover:text-primary px-3 py-2 rounded-lg border border-border-subtle hover:border-primary/40 transition-colors"
          >
            ← Назад
          </a>
        ) : (
          <a
            href="/articles/"
            class="text-sm text-text-muted hover:text-primary px-3 py-2 rounded-lg border border-border-subtle hover:border-primary/40 transition-colors"
          >
            ← Страница 1
          </a>
        )}

        <a
          href="/articles/"
          class="text-sm px-3 py-2 rounded-lg border border-border-subtle text-text-muted hover:border-primary/40 hover:text-primary transition-colors"
        >
          1
        </a>

        {Array.from({ length: totalPages - 1 }, (_, i) => i + 2).map((num) => (
          <a
            href={`/articles/page/${num}/`}
            class:list={[
              'text-sm px-3 py-2 rounded-lg border transition-colors',
              num === pageNum
                ? 'bg-primary/10 text-primary border-primary/20 font-medium'
                : 'text-text-muted border-border-subtle hover:border-primary/40 hover:text-primary',
            ]}
          >
            {num}
          </a>
        ))}

        {pageNum < totalPages && (
          <a
            href={`/articles/page/${pageNum + 1}/`}
            class="text-sm text-text-muted hover:text-primary px-3 py-2 rounded-lg border border-border-subtle hover:border-primary/40 transition-colors"
          >
            Вперёд →
          </a>
        )}
      </nav>
    </div>
  </section>

  <CTA
    title="Есть вопросы по разработке?"
    subtitle="Напишите — помогу разобраться и подскажу лучшее решение"
  />
</BaseLayout>
