---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';
import ServicesList from '../components/ServicesList.astro';
import ArticlesPreview from '../components/ArticlesPreview.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout
  title="Создаю продающие сайты для малого бизнеса"
  description="Веб-разработчик из Саратова. Лендинги, корпоративные сайты и интернет-магазины, которые приносят заявки и клиентов. Смотрите портфолио."
>
  <div class="opacity-0 translate-y-4 transition-all duration-500 ease-out" data-reveal>
    <Hero />
  </div>
  <div class="opacity-0 translate-y-4 transition-all duration-500 ease-out" data-reveal>
    <ProjectsGrid />
  </div>
  <div class="opacity-0 translate-y-4 transition-all duration-500 ease-out" data-reveal>
    <ServicesList />
  </div>
  <ArticlesPreview />
  <CTA secondaryCtaText="Скачать бриф сайта (PDF)" secondaryCtaHref="/brief/" />
</BaseLayout>
